# Binance API (public endpoints only - no keys needed for market data)
BINANCE_REST_BASE=https://api.binance.com
BINANCE_WS_BASE=wss://stream.binance.com:9443/ws
BINANCE_FUTURES_REST_BASE=https://fapi.binance.com
BINANCE_FUTURES_WS_BASE=wss://fstream.binance.com/ws

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_SCALP_CHANNEL_ID=-1001234567890
TELEGRAM_SWING_CHANNEL_ID=-1001234567891
TELEGRAM_RANGE_CHANNEL_ID=-1001234567892
TELEGRAM_TAPE_CHANNEL_ID=-1001234567893
TELEGRAM_FREE_CHANNEL_ID=-1001234567894
TELEGRAM_ADMIN_CHAT_ID=123456789

# AI / Sentiment (optional)
NEWS_API_KEY=
SOCIAL_SENTIMENT_API_KEY=

# Engine Settings
LOG_LEVEL=INFO
PAIR_FETCH_INTERVAL_HOURS=6
TOP_PAIRS_COUNT=50
