# 360-Crypto-scalping-V2 — Docker deployment configuration
# Copy this file to .env and fill in your values before running: docker compose up -d

# Binance API (public endpoints only - no keys needed for market data)
BINANCE_REST_BASE=https://api.binance.com
BINANCE_WS_BASE=wss://stream.binance.com:9443/ws
BINANCE_FUTURES_REST_BASE=https://fapi.binance.com
BINANCE_FUTURES_WS_BASE=wss://fstream.binance.com/ws

# Binance API (required for authenticated endpoints)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=8410996204:AAEky7CKTx450C4aBdTeKlLqlnyfq4U6wPI
TELEGRAM_SCALP_CHANNEL_ID=-1003809706320
TELEGRAM_SWING_CHANNEL_ID=-1003855571051
TELEGRAM_RANGE_CHANNEL_ID=-1003626740685
TELEGRAM_TAPE_CHANNEL_ID=-1003753420369
TELEGRAM_FREE_CHANNEL_ID=-1003730302765
TELEGRAM_ADMIN_CHAT_ID=710718010

# Multiple admin IDs (comma-separated)
# TELEGRAM_ADMIN_IDS=123456789,987654321

# AI / Sentiment (optional)
NEWS_API_KEY=
SOCIAL_SENTIMENT_API_KEY=

# Engine Settings
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_JSON=false
PAIR_FETCH_INTERVAL_HOURS=6
TOP_PAIRS_COUNT=50
SCAN_INTERVAL_SECONDS=1

# Redis (optional, for queue/cache persistence)
REDIS_URL=redis://localhost:6379/0

# Database (optional, for signal history persistence)
DATABASE_URL=

# Multi-exchange verification (optional)
SECOND_EXCHANGE_URL=
